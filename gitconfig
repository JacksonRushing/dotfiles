[user]
    name = Jackson Rushing
    email = jackson.rushing@outlook.com

[core]
    editor = micro
    pager = less -FRX

[alias]
    st = status -sb
    co = checkout
    br = branch
    ci = commit
    last = log -1 HEAD
    lg = log --oneline --graph --decorate --all -20
    unstage = reset HEAD --
    amend = commit --amend --no-edit

[color]
    ui = auto

[pull]
    rebase = false

[init]
    defaultBranch = main